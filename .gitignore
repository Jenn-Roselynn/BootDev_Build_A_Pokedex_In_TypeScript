# ==========================================
# Dependency Directories
# ==========================================
# Third-party packages downloaded via npm
node_modules/

# ==========================================
# Build and Output Products
# ==========================================
# Compiled JavaScript files generated by the TypeScript compiler
dist/

# ==========================================
# Environment and Sensitive Secrets
# ==========================================
# Local environment variables containing API keys or private configs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# Operating System & IDE Specific Files
# ==========================================
# macOS system files
.DS_Store
Thumbs.db

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/

# Visual Studio Code configuration workspace settings
.vscode/
!.vscode/extensions.json

# Log files generated by node or npm crashes
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*